# OpenCode Zen API key (required)
# Get yours at: https://opencode.ai/zen
OPENCODE_API_KEY=your_opencode_api_key_here

# HackerOne API key (optional — for your own resolved reports)
# Format: identifier:token
# Get at: https://hackerone.com/settings/api_token
H1_API_KEY=

# GitHub token (optional — increases rate limits for GitHub source)
GITHUB_TOKEN=
